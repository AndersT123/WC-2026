# Database Configuration
# For production, use PostgreSQL with asyncpg driver
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/worldcup
# For local development, SQLite works fine
DATABASE_URL=sqlite+aiosqlite:///./worldcup.db

# JWT Secret Key
# Generate a secure key with: openssl rand -hex 32
JWT_SECRET_KEY=your-secret-key-change-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=30

# Magic Link Settings
MAGIC_LINK_EXPIRE_MINUTES=15

# Email Settings (Brevo SMTP)
# Sign up at https://www.brevo.com/ to get SMTP credentials
FROM_EMAIL=noreply@yourdomain.com

# SMTP Settings (Brevo)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=your-brevo-smtp-user
SMTP_PASSWORD=your-brevo-smtp-password

# Frontend/Application URLs
# This is used to generate magic link URLs in emails
FRONTEND_URL=https://your-app-url.scw.cloud

# Rate Limiting
RATE_LIMIT_REQUESTS=3
RATE_LIMIT_PERIOD=900

# CORS Settings (comma-separated list)
# CORS_ORIGINS=http://localhost:3000,http://localhost:8000,https://your-production-domain.com

# Admin Configuration
# Comma-separated list of admin email addresses
# ADMIN_EMAILS_STR=admin@example.com,another-admin@example.com
